# Same key as frontend (VITE_GOOGLE_MAPS_API_KEY). Enable Distance Matrix API.
GOOGLE_MAPS_API_KEY=

# Path to Firebase Admin SDK JSON (Firebase Console → Service accounts → Generate key)
GOOGLE_APPLICATION_CREDENTIALS=

# Comma-separated IPs allowed to call this function (your public IP(s))
# Leave empty for local dev, or use 127.0.0.1 when testing through Vite proxy
ALLOWED_CALLER_IPS=

FIREBASE_PROJECT_ID=route-optimizer-11

# Local functions-framework port (default 8787; avoid 8080 on Windows)
# OPTIMIZER_PORT=8787
